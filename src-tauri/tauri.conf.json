{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StoneDiary",
  "version": "0.1.1",
  "identifier": "com.stonediary",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "道痕 StoneDiary",
        "width": 1440,
        "height": 960,
        "minWidth": 1080,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
